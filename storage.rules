rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow uploads to bookings folder
    match /bookings/{allPaths=**} {
      allow write: if true;  // Allow public uploads for booking images
      allow read: if true;   // Allow public reads
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

