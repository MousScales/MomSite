# Vercel Environment Variables
# Add these in your Vercel project: Settings → Environment Variables

# Supabase (required for booking APIs)
SUPABASE_URL=https://ecnbdqkqlxkfghjcbvwj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Or use SUPABASE_ANON_KEY if RLS allows the operations

# Stripe (required for payments - BOTH keys must be from same Stripe account)
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
